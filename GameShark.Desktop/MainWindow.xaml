<Window x:Class="GameShark.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameShark PDV - Terminal de Caixa" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#050508">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="GAMESHARK PDV" FontSize="32" FontWeight="Bold" Foreground="#00f3ff" FontFamily="Consolas"/>
            <TextBlock Text=" | Status da Conexão:" FontSize="18" Foreground="#6c757d" VerticalAlignment="Center" Margin="20,0,10,0"/>
            <TextBlock x:Name="txtStatus" Text="Aguardando teste..." FontSize="18" FontWeight="Bold" Foreground="#fbd304" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#ffc107" BorderThickness="1" CornerRadius="5" Background="#111118">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Terminal Operacional da Loja Física" FontSize="24" Foreground="#fff" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <Button x:Name="btnTestarApi" Content="TESTAR CONEXÃO COM A API" FontSize="16" FontWeight="Bold" Background="#bc13fe" Foreground="#fff" Padding="20,15" Click="btnTestarApi_Click" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="GameShark OmniChannel v1.0" Foreground="#6c757d" HorizontalAlignment="Right" Margin="0,20,0,0"/>
    </Grid>
</Window>