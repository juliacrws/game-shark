@model IEnumerable<GameShark.Domain.Entities.Categoria>
@{
    ViewData["Title"] = "Categorias";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="text-info fw-bold"><i class="bi bi-tags"></i> Categorias de Loot</h2>
    <div>
        <a href="/Admin/Manage" class="btn btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i> Voltar ao Painel</a>
        <a asp-action="Create" class="btn btn-info fw-bold text-dark"><i class="bi bi-plus-lg"></i> Nova Categoria</a>
    </div>
</div>

<div class="table-responsive shadow-lg rounded">
    <table class="table table-dark table-hover align-middle border-secondary">
        <thead class="bg-black text-info">
            <tr>
                <th>Nome</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.Nome</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>