@model GameShark.Web.Areas.Admin.Models.ProdutoEditVm

<div class="row">
    <div class="col-md-8">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImagemUrl" />

        <div class="form-floating mb-3">
            <input asp-for="Nome" class="form-control bg-dark text-light border-secondary" placeholder="Nome" />
            <label asp-for="Nome" class="text-muted">Nome do Loot</label>
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="form-floating mb-3">
            <textarea asp-for="Descricao" class="form-control bg-dark text-light border-secondary" placeholder="Descrição" style="height: 100px"></textarea>
            <label asp-for="Descricao" class="text-muted">Descrição Épica</label>
            <span asp-validation-for="Descricao" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="form-floating">
                    <input asp-for="Preco" class="form-control bg-dark text-light border-secondary" placeholder="Preço" type="number" step="0.01" />
                    <label asp-for="Preco" class="text-muted">Preço (R$)</label>
                    <span asp-validation-for="Preco" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="form-floating">
                    <input asp-for="Estoque" class="form-control bg-dark text-light border-secondary" placeholder="Estoque" type="number" />
                    <label asp-for="Estoque" class="text-muted">Estoque (Qtd)</label>
                    <span asp-validation-for="Estoque" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label text-info small fw-bold">Categoria</label>
                <select asp-for="CategoriaId" class="form-select bg-dark text-light border-secondary" asp-items="ViewBag.Categorias">
                    <option value="">-- Selecione --</option>
                </select>
                <span asp-validation-for="CategoriaId" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-4">
                <label class="form-label text-info small fw-bold">Plataforma</label>
                <select asp-for="PlataformaId" class="form-select bg-dark text-light border-secondary" asp-items="ViewBag.Plataformas">
                    <option value="">-- Selecione --</option>
                </select>
                <span asp-validation-for="PlataformaId" class="text-danger small"></span>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-black border-info h-100">
            <div class="card-body text-center d-flex flex-column justify-content-center">
                <i class="bi bi-cloud-arrow-up text-info mb-3" style="font-size: 3rem;"></i>
                <label asp-for="Capa" class="form-label text-light fw-bold">Upload de Capa</label>
                <input asp-for="Capa" type="file" class="form-control bg-dark text-light border-secondary mt-2" accept="image/*" />
                
                @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                {
                    <p class="text-muted small mt-3 mb-1">Capa Atual:</p>
                    <img src="@Model.ImagemUrl" class="img-fluid rounded border border-secondary" alt="Capa atual" style="max-height: 150px; object-fit: cover;" />
                }
            </div>
        </div>
    </div>
</div>