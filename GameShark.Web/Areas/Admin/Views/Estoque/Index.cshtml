@model IEnumerable<GameShark.Domain.Entities.Produto>
@{
    ViewData["Title"] = "Controle de Armazém";
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-neon-cyan fw-bold text-uppercase" style="font-family: 'Orbitron', sans-serif;">
            <i class="bi bi-boxes"></i> Central de Estoque
        </h2>
        
        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
        {
            <a href="/Admin/Dashboard" class="btn btn-outline-secondary btn-sm fw-bold">
                <i class="bi bi-arrow-left"></i> Voltar à Boss Room
            </a>
        }
        else
        {
            <a href="/" class="btn btn-outline-secondary btn-sm fw-bold">
                <i class="bi bi-arrow-left"></i> Voltar à Vitrine
            </a>
        }
    </div>

    <div class="card card-geek shadow-lg bg-darker-bg border-secondary border-1">
        <div class="card-body p-0 overflow-hidden rounded">
            <table class="table table-dark table-hover table-borderless align-middle mb-0">
                <thead class="border-bottom border-neon-cyan text-uppercase" style="font-family: 'Orbitron', sans-serif;">
                    <tr class="bg-black">
                        <th class="ps-4">Item (Loot)</th>
                        <th>Plataforma</th>
                        <th class="text-center">Status Crítico</th>
                        <th class="text-center">Qtd. Atual</th>
                        <th class="text-center pe-4">Ação Rápida</th>
                    </tr>
                </thead>
                <tbody style="font-family: 'Rajdhani', sans-serif;">
                    @foreach (var item in Model)
                    {
                        // A LÓGICA DO RADAR: Define a cor do alerta dependendo de quantas cópias sobraram
                        string statusCor = item.Estoque > 10 ? "text-neon-green" : (item.Estoque > 0 ? "text-warning" : "text-danger");
                        string statusIcon = item.Estoque > 10 ? "bi-shield-check" : (item.Estoque > 0 ? "bi-exclamation-triangle" : "bi-x-octagon-fill");
                        string statusTexto = item.Estoque > 10 ? "Estável" : (item.Estoque > 0 ? "Acabando" : "Esgotado");

                        <tr class="border-bottom border-secondary">
                            <td class="ps-4 fw-bold text-light fs-5">@item.Nome</td>
                            <td><span class="badge border border-secondary text-light">@(item.Plataforma?.Nome ?? "N/A")</span></td>
                            
                            <td class="text-center">
                                <span class="@statusCor fw-bold text-uppercase" style="letter-spacing: 1px;">
                                    <i class="bi @statusIcon"></i> @statusTexto
                                </span>
                            </td>
                            
                            <td class="text-center fs-4 fw-bold @statusCor">
                                @item.Estoque
                            </td>
                            
                            <td class="text-center pe-4">
                                <form asp-action="Atualizar" method="post" class="d-flex justify-content-center gap-2">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="number" name="novaQuantidade" value="@item.Estoque"
                                           class="form-control form-control-sm bg-black text-light border-secondary text-center"
                                           style="width: 90px; font-family: 'Orbitron', sans-serif;" min="0" />
                                    
                                    <button type="submit" class="btn btn-sm btn-outline-neon-cyan fw-bold">
                                        <i class="bi bi-arrow-repeat"></i> SAVE
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>