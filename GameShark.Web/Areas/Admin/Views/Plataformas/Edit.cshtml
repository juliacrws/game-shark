@model GameShark.Domain.Entities.Plataforma
@{
    ViewData["Title"] = "Editar Plataforma";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card bg-black border-warning shadow-lg">
            <div class="card-header border-warning text-warning fw-bold">
                <i class="bi bi-pencil"></i> Alterar Plataforma
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Nome" class="form-control bg-dark text-light border-secondary" placeholder="Name" />
                        <label asp-for="Nome" class="text-muted">Nome da Plataforma</label>
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
                        <button type="submit" class="btn btn-warning fw-bold text-dark px-4">Salvar Alterações</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>