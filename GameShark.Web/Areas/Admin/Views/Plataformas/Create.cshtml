@model GameShark.Domain.Entities.Plataforma
@{
    ViewData["Title"] = "Nova Plataforma";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card bg-black border-info shadow-lg">
            <div class="card-header border-info text-info fw-bold">
                <i class="bi bi-joystick"></i> Forjar Nova Plataforma
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Nome" class="form-control bg-dark text-light border-secondary" placeholder="Name" />
                        <label asp-for="Nome" class="text-muted">Nome da Plataforma (ex: PS5, PC)</label>
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-info fw-bold text-dark px-4">Salvar Plataforma</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>