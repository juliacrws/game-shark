@model GameShark.Infrastructure.Entities.ApplicationUser
@{
    ViewData["Title"] = "Banir Player";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="alert alert-danger bg-black border-danger p-5 shadow-lg">
            <i class="bi bi-hammer text-danger display-1 mb-3"></i>
            <h2 class="text-light mt-3">Banir Player do Servidor?</h2>
            <p class="text-muted fs-5">Você está prestes a excluir a conta de: <strong class="text-danger">@Model.NomeCompleto</strong> (@Model.Email)</p>
            
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger btn-lg fw-bold px-5 mt-3"><i class="bi bi-skull"></i> BANIR CONTA</button>
                <div class="mt-4">
                    <a asp-action="Index" class="btn btn-link text-muted">Cancelar e poupar o player</a>
                </div>
            </form>
        </div>
    </div>
</div>