@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@inject GameShark.Infrastructure.Persistence.AppDbContext DbContext
@inject Microsoft.AspNetCore.Identity.UserManager<GameShark.Infrastructure.Entities.ApplicationUser> UserManager
@{
    int cartCount = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (userId != null)
        {
            cartCount = DbContext.CarrinhoItems.Where(c => c.UsuarioId == userId).Sum(c => c.Quantidade);
        }
    }
}
<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameShark</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* AJUSTES DE VISUALIZAÇÃO AMPLIADA */
        
        /* 1. Toast (Pop-up de canto) maior */
        .toast-geek-custom {
            width: 400px !important; /* Aumentado */
            background-color: rgba(15, 15, 20, 0.95) !important;
            backdrop-filter: blur(10px);
        }

        /* 2. Modal de Reserva Ampliado */
        .modal-xl-custom {
            max-width: 650px; /* Largura maior para melhor leitura */
        }

        .rounded-geek {
            border-radius: 15px !important;
        }

        .holographic-flicker {
            animation: flicker 2s infinite;
        }

        @@keyframes flicker {
            0% { opacity: 1; filter: drop-shadow(0 0 5px #00ff41); }
            50% { opacity: 0.8; filter: drop-shadow(0 0 15px #00ff41); }
            100% { opacity: 1; filter: drop-shadow(0 0 5px #00ff41); }
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-geek py-3 fixed-top shadow-lg" style="background-color: rgba(15, 15, 20, 0.85) !important; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
            <div class="container-fluid px-4">
                <a class="navbar-brand text-neon-cyan fw-bold d-flex align-items-center gap-2 logo-cyber me-4" asp-area="" asp-controller="Home" asp-action="Index" style="letter-spacing: 2px;">
                    <img src="~/images/favicon.png" alt="Logo GameShark" style="height: 38px; width: auto; object-fit: contain; opacity: 0.9; filter: drop-shadow(0px 4px 8px rgba(0, 243, 255, 0.4)); transition: all 0.3s ease;" />
                    GAMESHARK
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav align-items-center mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-uppercase fw-bold text-light transition-hover" asp-controller="Home" asp-action="Index">Catálogo</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-uppercase text-muted transition-hover" href="#" data-bs-toggle="dropdown">Plataformas</a>
                            <ul class="dropdown-menu dropdown-menu-dark bg-darker-bg border-secondary">
                                <li><a class="dropdown-item text-light transition-hover" href="/Home?busca=PlayStation">PlayStation</a></li>
                                <li><a class="dropdown-item text-light transition-hover" href="/Home?busca=Xbox">Xbox</a></li>
                                <li><a class="dropdown-item text-light transition-hover" href="/Home?busca=PC">PC Master Race</a></li>
                            </ul>
                        </li>
                    </ul>

                    <form class="d-flex mx-auto w-100 px-lg-4" style="max-width: 500px;" asp-controller="Home" asp-action="Index" method="get">
                        <div class="input-group">
                            <input type="text" name="busca" class="form-control form-control-geek border-secondary" placeholder="Buscar loot (ex: Resident Evil)..." value="@ViewData["BuscaAtual"]">
                            <button class="btn btn-outline-neon-cyan fw-bold px-4" type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </form>

                    <ul class="navbar-nav align-items-center gap-2 mt-3 mt-lg-0">
                        @if (User.IsInRole("Admin") || User.IsInRole("Estoquista"))
                        {
                            <li class="nav-item"><a class="nav-link text-neon-green fw-bold" href="/Admin/Estoque" title="Armazém"><i class="bi bi-boxes fs-5"></i></a></li>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerente"))
                        {
                            <li class="nav-item"><a class="nav-link text-light fw-bold" href="/Admin/Dashboard" title="Boss Room"><i class="bi bi-cpu text-neon-cyan fs-5"></i></a></li>
                            <li class="nav-item"><a class="nav-link text-neon-green fw-bold" href="/Admin/Caixa" title="Caixa"><i class="bi bi-safe2 fs-5"></i></a></li>
                            <li class="nav-item"><a class="nav-link text-warning fw-bold" href="/Admin/Auditoria" title="Auditoria"><i class="bi bi-shield-lock fs-5"></i></a></li>
                            <li class="nav-item"><a class="nav-link text-warning fw-bold" href="/Admin/Radar" title="Radar de Loot"><i class="bi bi-radar fs-5" style="filter: drop-shadow(0 0 5px #ffc107);"></i></a></li>
                        }
                        
                        <li class="nav-item ms-lg-2">
                            <a asp-controller="Carrinho" asp-action="Index" class="btn btn-outline-secondary btn-sm text-light fw-bold position-relative d-flex align-items-center gap-2 px-3 py-2 border-secondary" style="font-family: 'Orbitron', sans-serif;">
                                <i class="bi bi-cart3 fs-5 text-neon-cyan"></i> Cart
                                @if (cartCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-neon-cyan text-dark" style="font-size: 0.75rem;">@cartCount</span>
                                }
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var appUser = await UserManager.GetUserAsync(User);
                            var nomeParaExibir = !string.IsNullOrEmpty(appUser?.Apelido) ? appUser.Apelido : (appUser?.NomeCompleto?.Split(' ')[0] ?? "Player");
                            
                            <li class="nav-item dropdown ms-2">
                                <a class="text-decoration-none d-flex align-items-center ps-3 dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <div style="width: 42px; height: 42px; background: var(--neon-cyan); padding: 2px; clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);">
                                        <img src="@(appUser?.FotoPerfilUrl ?? "/images/default-avatar.png")"
                                             style="width: 100%; height: 100%; object-fit: cover; clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%); transition: all 0.3s ease;"
                                             onmouseover="this.style.transform='scale(1.1)'"
                                             onmouseout="this.style.transform='scale(1)'" />
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end bg-darker-bg border-secondary shadow-lg mt-2">
                                    <li><h6 class="dropdown-header text-neon-cyan fw-bold">Player: @nomeParaExibir</h6></li>
                                    <li><a class="dropdown-item text-light transition-hover" href="/Perfil"><i class="bi bi-person-lines-fill me-2"></i> Meu Perfil</a></li>
                                    <li><hr class="dropdown-divider border-secondary"></li>
                                    <li>
                                        <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="m-0 p-0 px-3 py-1">
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100 fw-bold"><i class="bi bi-power"></i> Desconectar</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-3">
                                <a class="btn btn-neon-cyan btn-sm px-4 py-2 fw-bold text-uppercase" asp-controller="Auth" asp-action="Login">Acessar</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3 pt-5 mt-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-geek mt-auto py-5 position-relative">
        <div class="container px-4">
            <div class="row gy-5">
                <div class="col-lg-4 col-md-6">
                    <a class="text-neon-cyan fw-bold d-flex align-items-center gap-2 logo-cyber mb-3 text-decoration-none fs-4" style="letter-spacing: 2px;" href="/">
                        <img src="~/images/favicon.png" alt="Logo GameShark" style="height: 50px; width: auto; object-fit: contain; opacity: 0.9; filter: drop-shadow(0px 6px 10px rgba(0, 243, 255, 0.4)); transition: all 0.3s ease;" />
                        GAMESHARK
                    </a>
                    <p class="text-muted pe-lg-4 mb-4" style="font-size: 0.95rem;">
                        O seu terminal definitivo para loot, hardware e tudo que você precisa para platinar a vida real.
                        Level up your setup.
                    </p>
                    <div class="d-flex gap-3 social-links">
                        <a href="#" class="btn btn-outline-neon-cyan rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="bi bi-discord"></i></a>
                        <a href="#" class="btn btn-outline-neon-cyan rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="btn btn-outline-neon-cyan rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="bi bi-twitch"></i></a>
                        <a href="#" class="btn btn-outline-neon-cyan rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <h5 class="text-light fw-bold mb-4" style="font-family: 'Orbitron', sans-serif;">CONTATO_</h5>
                    <ul class="list-unstyled text-muted contact-info">
                        <li class="mb-3 d-flex align-items-start gap-3">
                            <i class="bi bi-geo-alt text-neon-cyan fs-4 mt-1"></i>
                            <div>
                                <span class="d-block text-light fw-bold">Matriz Operacional</span>
                                Av. Paulista, 1578 - Bela Vista<br>São Paulo - SP, 01310-200
                            </div>
                        </li>
                        <li class="mb-3 d-flex align-items-center gap-3">
                            <i class="bi bi-telephone text-neon-cyan fs-4"></i>
                            <span class="fs-5">(11) 4002-8922</span>
                        </li>
                        <li class="d-flex align-items-center gap-3">
                            <i class="bi bi-envelope text-neon-cyan fs-4"></i>
                            <span>suporte@gameshark.com.br</span>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-12">
                    <h5 class="text-light fw-bold mb-4" style="font-family: 'Orbitron', sans-serif;">RADAR DE LOCALIZAÇÃO_</h5>
                    <div class="map-container rounded border border-secondary overflow-hidden shadow-lg p-1 bg-darker-bg" style="border-width: 2px !important;">
                        <iframe class="dark-map rounded w-100"
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3657.1065964223285!2d-46.6539054!3d-23.5612841!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce59c8da0aa315%3A0xd59f9431f2c9776a!2sAv.%20Paulista%2C%201578%20-%20Bela%20Vista%2C%20S%C3%A3o%20Paulo%20-%20SP%2C%2001310-200!5e0!3m2!1spt-BR!2sbr!4v1700000000000!5m2!1spt-BR!2sbr"
                                height="180"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>
            </div>
            
            <div class="row mt-5 pt-4 border-top border-secondary">
                <div class="col-12 d-flex justify-content-between align-items-center text-muted" style="font-size: 0.85rem;">
                    <span>© 2026 GameShark Systems. Todos os direitos reservados.</span>
                    <span class="badge bg-dark border border-secondary text-muted">System v1.0.4</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="toast-container position-fixed bottom-0 end-0 p-4" style="z-index: 10000;">
            <div id="geekToast" class="toast align-items-center bg-darker-bg border-neon-cyan shadow-lg toast-geek-custom" role="alert" aria-live="assertive" aria-atomic="true" style="border-width: 2px;">
                <div class="d-flex">
                    <div class="toast-body text-neon-cyan fw-bold fs-5 p-4" style="font-family: 'Orbitron', sans-serif; letter-spacing: 1px;">
                        <i class="bi bi-check2-square me-2 fs-4"></i> @TempData["MensagemSucesso"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-3 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
            var toastEl = document.getElementById('geekToast');
            if(toastEl) {
                // TEMPO AUMENTADO: delay: 8000 (8 segundos)
                var toast = new bootstrap.Toast(toastEl, { delay: 8000 });
                toast.show();
            }
            });
        </script>
    }

    @if (TempData["ReservaSucesso"] != null)
    {
        <div class="modal fade" id="modalReservaSucesso" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
            <div class="modal-dialog modal-dialog-centered modal-xl-custom">
                <div class="modal-content bg-darker-bg border-neon-green shadow-lg rounded-geek" style="border-width: 2px;">
                    
                    <div class="modal-header border-bottom border-secondary p-4">
                        <h4 class="modal-title text-neon-green fw-bold text-uppercase" style="font-family: 'Orbitron', sans-serif;">
                            <i class="bi bi-check-circle-fill me-2"></i> Reserva Confirmada!
                        </h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    
                    <div class="modal-body p-5 text-center">
                        <i class="bi bi-box-seam display-2 text-neon-green mb-4 holographic-flicker d-block"></i>
                        <h3 class="text-light fw-bold mb-3">LOOT GARANTIDO!</h3>
                        <p class="text-muted font-monospace mb-4 fs-5">O sistema processou sua requisição. Seu equipamento foi separado e aguarda extração.</p>

                        <div class="bg-black p-4 rounded border border-secondary text-start mb-4 shadow-sm">
                            <p class="mb-2 text-light fs-5"><i class="bi bi-geo-alt-fill text-neon-cyan me-2"></i><strong>Ponto de Extração:</strong></p>
                            <p class="text-muted font-monospace ms-4 mb-4 fs-6">@(TempData["ReservaEndereco"] ?? "Av. Paulista, 1578 - Bela Vista, São Paulo - SP")</p>

                            <p class="mb-2 text-light fs-5"><i class="bi bi-clock-fill text-neon-cyan me-2"></i><strong>Tempo Limite para Retirada:</strong></p>
                            <p class="text-warning font-monospace ms-4 mb-0 fw-bold fs-4" style="text-shadow: 0 0 10px rgba(255, 193, 7, 0.3);">
                                @(TempData["ReservaPrazo"] ?? "48 HORAS")
                            </p>
                        </div>
                        
                        <div class="alert alert-dark border-danger bg-transparent text-danger font-monospace py-3" style="font-size: 0.85rem; border-style: dashed;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> PROTOCOLO: Se o loot não for resgatado no prazo, os itens retornam ao estoque global.
                        </div>
                    </div>
                    
                    <div class="modal-footer border-top border-secondary justify-content-center p-4">
                        <button type="button" class="btn btn-neon-green fw-bold text-uppercase px-5 py-3 shadow fs-5" data-bs-dismiss="modal" style="font-family: 'Orbitron', sans-serif; letter-spacing: 2px;">
                            ENTENDIDO, CÂMBIO! <i class="bi bi-send-check ms-2"></i>
                        </button>
                    </div>
                    
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
            var modalElement = document.getElementById('modalReservaSucesso');
            if(modalElement) {
                var modal = new bootstrap.Modal(modalElement);
                modal.show();
            }
            });
        </script>
    }
</body>
</html>