@model GameShark.Web.Models.Paging<GameShark.Web.Models.ProdutoDto>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @if (!Model.Items.Any())
    {
        <div class="col-12 text-center mt-5">
            <h4 class="text-muted">Nenhum loot encontrado com esses filtros. 😢</h4>
        </div>
    }

    @foreach (var produto in Model.Items)
    {
        <div class="col">
            <div class="card h-100 bg-black border-secondary shadow-sm">
                <div class="bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-image text-dark" style="font-size: 3rem;"></i>
                </div>
                <div class="card-body">
                    <span class="badge bg-info text-dark mb-2">@produto.PlataformaNome</span>
                    <span class="badge bg-secondary mb-2">@produto.CategoriaNome</span>
                    
                    <h5 class="card-title text-light fw-bold">@produto.Nome</h5>
                    <p class="card-text text-muted small">@produto.Descricao</p>
                </div>
                <div class="card-footer border-secondary bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="text-success mb-0 fw-bold">R$ @produto.Preco.ToString("N2")</h5>
                    <button class="btn btn-sm btn-outline-info"><i class="bi bi-cart-plus"></i></button>
                </div>
            </div>
        </div>
    }
</div>