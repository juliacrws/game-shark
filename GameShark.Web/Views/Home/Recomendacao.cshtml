@model IEnumerable<GameShark.Domain.Entities.Produto>
@{
    ViewData["Title"] = "Resultado do Oráculo";
}

<div class="text-center mt-5 mb-5">
    <h2 class="text-neon-purple fw-bold text-uppercase mb-3" style="font-family: 'Orbitron', sans-serif;">
        <i class="bi bi-stars"></i> Match Encontrado
    </h2>
    <p class="lead text-light font-monospace">@ViewData["MensagemOraculo"]</p>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5 justify-content-center">
    @if (Model != null && Model.Any())
    {
        foreach (var produto in Model)
        {
            <div class="col">
                <div class="card h-100 bg-darker-bg border-neon-purple cyber-card shadow-sm position-relative">
                    
                    <div class="position-relative overflow-hidden bg-black rounded-top" style="height: 280px;">
                        @if (!string.IsNullOrEmpty(produto.ImagemUrl))
                        {
                            <img src="@produto.ImagemUrl" class="w-100 h-100 object-fit-cover card-img-top cyber-img" alt="@produto.Nome" />
                        }
                        <div class="position-absolute top-0 end-0 m-2">
                            <span class="badge bg-black border border-neon-purple text-neon-purple fw-bold text-uppercase shadow-sm">
                                @(produto.Plataforma?.Nome ?? "Digital")
                            </span>
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column p-3">
                        <div class="mb-2">
                            <span class="badge bg-secondary text-uppercase" style="font-family: 'Orbitron', sans-serif; font-size: 0.7rem;">@produto.Categoria?.Nome</span>
                        </div>
                        <h5 class="card-title fw-bold text-light mb-1 text-truncate text-uppercase" title="@produto.Nome" style="font-family: 'Orbitron', sans-serif;">@produto.Nome</h5>
                        
                        <div class="mt-auto pt-3 border-top border-secondary d-flex justify-content-between align-items-center">
                            <span class="fs-4 fw-bold text-neon-green" style="font-family: 'Rajdhani', sans-serif;">R$ @produto.Preco.ToString("N2")</span>
                            <form asp-controller="Carrinho" asp-action="Adicionar" method="post" class="m-0">
                                <input type="hidden" name="id" value="@produto.Id" />
                                <button type="submit" class="btn btn-outline-neon-purple fw-bold rounded-circle d-flex justify-content-center align-items-center cyber-buy-btn" title="Garantir Loot" style="width: 45px; height: 45px;">
                                    <i class="bi bi-cart-plus-fill fs-5"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<div class="text-center mb-5">
    <a href="/Home/Quiz" class="btn btn-outline-secondary fw-bold px-4"><i class="bi bi-arrow-repeat"></i> Refazer Quiz</a>
    <a href="/" class="btn btn-neon-cyan fw-bold px-4 ms-2">Voltar ao Catálogo</a>
</div>