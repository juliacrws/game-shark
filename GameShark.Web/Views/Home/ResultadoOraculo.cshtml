@model IEnumerable<GameShark.Domain.Entities.Produto>
@{
    ViewData["Title"] = "Resultado do Oráculo";
}

<div class="container mt-5 pt-5">
    <div class="text-center mb-5">
        <div class="d-inline-block p-3 border border-neon-purple bg-darker-bg rounded-geek shadow-lg">
            <h2 class="text-neon-purple fw-bold mb-0" style="font-family: 'Orbitron', sans-serif;">
                <i class="bi bi-cpu-fill holographic-flicker"></i> RESULTADO DO ESCANEAMENTO
            </h2>
            <div class="mt-2 font-monospace text-muted small">
                TARGET: <span class="text-neon-cyan">@ViewData["Vibe"]</span> | 
                HW_ID: <span class="text-neon-cyan">@ViewData["Plataforma"]</span>
            </div>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        @if (!Model.Any())
        {
            <div class="col-md-6 text-center py-5">
                <i class="bi bi-shield-slash display-1 text-danger mb-4"></i>
                <h3 class="text-light">SISTEMA: NENHUM LOOT ENCONTRADO</h3>
                <p class="text-muted">O algoritmo não encontrou itens compatíveis nesta zona do banco de dados.</p>
                <a asp-action="Quiz" class="btn btn-outline-neon-cyan mt-3">RECALIBRAR ORÁCULO</a>            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 bg-darker-bg border-secondary card-loot-hover transition-all">
                        <div class="position-relative">
                            <img src="@item.ImagemUrl" class="card-img p-3" alt="@item.Nome" style="height: 250px; object-fit: contain;">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-neon-purple shadow-sm">MATCH ENCONTRADO</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column text-center">
                            <h5 class="text-light fw-bold mb-2">@item.Nome</h5>
                            <p class="text-muted small flex-grow-1">@item.Descricao</p>
                            <div class="fs-4 fw-bold text-neon-green mb-3">R$ @item.Preco.ToString("N2")</div>
                            <a href="/Produto/Detalhes/@item.Id" class="btn btn-neon-cyan fw-bold text-uppercase">Ver Data-Sheet</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="text-center mt-5">
    <a asp-action="Quiz" class="btn btn-link text-muted text-decoration-none">            
    <i class="bi bi-arrow-left"></i> Voltar ao Oráculo
    c</a>
    </div>
</div>

<style>
    .card-loot-hover:hover {
        border-color: #bc13fe !important;
        transform: translateY(-8px);
        box-shadow: 0 0 25px rgba(188, 19, 254, 0.4);
    }
    .text-neon-purple { color: #bc13fe !important; }
    .border-neon-purple { border: 2px solid #bc13fe !important; }
    .bg-neon-purple { background-color: #bc13fe !important; color: #fff; }
</style>