@model IEnumerable<GameShark.Domain.Entities.Produto>
@using GameShark.Domain.Enums
@{
    ViewData["Title"] = "Vitrine Principal";
}

@functions {
    // Mantive a sua lógica de segurança de cores!
    public string ObterCorClassificacao(ClassificacaoIndicativa classificacao)
    {
        return classificacao switch
        {
            ClassificacaoIndicativa.Livre => "#0c9447",
            ClassificacaoIndicativa.Dez => "#0f75bc",
            ClassificacaoIndicativa.Doze => "#fbd304",
            ClassificacaoIndicativa.Quatorze => "#f47321",
            ClassificacaoIndicativa.Dezesseis => "#ed1c24",
            ClassificacaoIndicativa.Dezoito => "#000000",
            _ => "#6c757d"
        };
    }

    public string ObterTextoClassificacao(ClassificacaoIndicativa classificacao)
    {
        return classificacao == ClassificacaoIndicativa.Livre ? "L" : ((int)classificacao).ToString();
    }
}

<div class="row mb-4 mt-3">
    <div class="col-12 text-center py-5 rounded-geek border border-secondary position-relative overflow-hidden shadow-lg" style="background: linear-gradient(180deg, #050508 0%, #111118 100%);">
        
        <div class="position-absolute w-100 h-100" style="top:0; left:0; background-image: radial-gradient(rgba(0, 243, 255, 0.1) 1px, transparent 1px); background-size: 20px 20px; opacity: 0.3;"></div>
        
        <div class="position-relative" style="z-index: 2;">
            <h1 class="display-3 fw-bold text-light mb-3 text-uppercase" style="font-family: 'Orbitron', sans-serif;">
                Bem-vindo à <span class="text-neon-cyan" style="text-shadow: 0 0 20px rgba(0, 243, 255, 0.6);">GameShark</span>
            </h1>
            <p class="lead text-muted font-monospace mb-4 fs-5">O maior arsenal de loot do submundo cibernético.</p>
            
            <a href="#vitrine" class="btn btn-neon-cyan btn-lg fw-bold text-uppercase px-5 py-3 shadow">
                <i class="bi bi-crosshair me-2"></i> Explorar Arsenal
            </a>
        </div>
    </div>
</div>

<div class="row mb-5">
    <div class="col-12">
        <div class="card card-geek bg-darker-bg border-neon-purple shadow-lg overflow-hidden position-relative">
            <div class="position-absolute w-100 h-100" style="background: radial-gradient(circle at right, rgba(188, 19, 254, 0.15) 0%, transparent 50%); top:0; left:0;"></div>
            
            <div class="card-body p-4 p-md-5 d-flex flex-column flex-md-row align-items-center justify-content-between position-relative" style="z-index: 2;">
                <div class="d-flex align-items-center mb-4 mb-md-0">
                    <i class="bi bi-cpu display-4 text-neon-purple me-4" style="filter: drop-shadow(0 0 10px rgba(188, 19, 254, 0.5));"></i>
                    <div>
                        <h3 class="text-uppercase fw-bold text-light mb-1" style="font-family: 'Orbitron', sans-serif;">Não sabe o que jogar?</h3>
                        <p class="text-muted font-monospace mb-0 fs-6">Consulte o <span class="text-neon-purple fw-bold">Oráculo de Loot</span> e deixe nosso algoritmo encontrar o match perfeito para a sua vibe.</p>
                    </div>
                </div>
                <a href="/Home/Quiz" class="btn btn-neon-purple btn-lg fw-bold text-uppercase px-4 shadow-lg" style="font-family: 'Orbitron', sans-serif; letter-spacing: 1px;">
                    <i class="bi bi-magic me-2"></i> Iniciar Quiz
                </a>
            </div>
        </div>
    </div>
</div>
<div id="vitrine">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom border-secondary pb-3">
        <h3 class="text-light fw-bold text-uppercase mb-0" style="font-family: 'Orbitron', sans-serif; letter-spacing: 1px;">
            <i class="bi bi-grid-3x3-gap-fill text-neon-cyan me-2"></i> Catálogo Completo
        </h3>
        <span class="text-muted font-monospace">@(Model?.Count() ?? 0) Itens encontrados</span>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
        @if (Model != null && Model.Any())
        {
            foreach (var produto in Model)
            {
                <div class="col">
                    <div class="card h-100 bg-darker-bg border-secondary cyber-card transition-hover shadow-sm position-relative">
                        
                        <div class="position-absolute d-flex align-items-center justify-content-center fw-bold shadow-sm"
                             style="top: 10px; left: 10px; width: 35px; height: 35px; border-radius: 4px;
                            background-color: @ObterCorClassificacao(produto.Classificacao);
                            color: @(produto.Classificacao == ClassificacaoIndicativa.Doze ? "#000" : "#fff");
                            border: @(produto.Classificacao == ClassificacaoIndicativa.Dezoito ? "1px solid #fff" : "none");
                            font-size: 1.2rem; z-index: 2; font-family: 'Orbitron', sans-serif;">
                            @ObterTextoClassificacao(produto.Classificacao)
                        </div>

                        <div class="position-relative overflow-hidden bg-black rounded-top" style="height: 280px;">
                            @if (!string.IsNullOrEmpty(produto.ImagemUrl))
                            {
                                <img src="@produto.ImagemUrl" class="w-100 h-100 object-fit-cover card-img-top cyber-img" alt="@produto.Nome" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                    <i class="bi bi-controller text-muted display-1"></i>
                                </div>
                            }
                            
                            <div class="position-absolute top-0 end-0 m-2" style="z-index: 2;">
                                <span class="badge bg-black border border-neon-cyan text-neon-cyan fw-bold text-uppercase shadow-sm" style="letter-spacing: 1px;">
                                    @(produto.Plataforma?.Nome ?? "Digital")
                                </span>
                            </div>
                        </div>

                        <div class="card-body d-flex flex-column p-3">
                            <div class="mb-2">
                                <span class="badge bg-secondary text-uppercase" style="font-family: 'Orbitron', sans-serif; font-size: 0.7rem;">@produto.Categoria?.Nome</span>
                            </div>
                            
                            <h5 class="card-title fw-bold text-light mb-1 text-truncate text-uppercase" title="@produto.Nome" style="font-family: 'Orbitron', sans-serif;">@produto.Nome</h5>
                            
                            <div class="mt-auto pt-3 border-top border-secondary d-flex justify-content-between align-items-center position-relative">
                                
                                @if (produto.Estoque == 1)
                                {
                                    <div class="position-absolute w-100 text-center" style="top: -20px; left: 0;">
                                        <span class="badge bg-warning text-dark fw-bold border border-warning shadow-sm" style="letter-spacing: 1px; font-size: 0.7rem; animation: pulse 2s infinite;">
                                            <i class="bi bi-exclamation-triangle-fill"></i> LAST UNIT!
                                        </span>
                                    </div>
                                }

                                <span class="fs-4 fw-bold @(produto.Estoque > 0 ? "text-neon-green" : "text-muted text-decoration-line-through")" style="font-family: 'Rajdhani', sans-serif;">R$ @produto.Preco.ToString("N2")</span>
                                
                                @if (produto.Estoque > 0)
                                {
                                    <div class="d-flex gap-2">
                                        <a href="/Home/Details/@produto.Id" class="btn btn-outline-secondary btn-sm rounded-circle d-flex justify-content-center align-items-center" title="Details" style="width: 45px; height: 45px;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-controller="Carrinho" asp-action="Adicionar" method="post" class="m-0">
                                            <input type="hidden" name="id" value="@produto.Id" />
                                            <button type="submit" class="btn btn-outline-neon-cyan fw-bold rounded-circle d-flex justify-content-center align-items-center cyber-buy-btn" title="Add to Cart" style="width: 45px; height: 45px;">
                                                <i class="bi bi-cart-plus-fill fs-5"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-outline-warning btn-sm fw-bold rounded px-3 py-2 d-flex align-items-center gap-2 cyber-buy-btn" data-bs-toggle="modal" data-bs-target="#notifyModal-@produto.Id" style="letter-spacing: 1px; font-size: 0.75rem;">
                                        <i class="bi bi-bell-fill"></i> NOTIFY ME
                                    </button>

                                    <div class="modal fade" id="notifyModal-@produto.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content bg-darker-bg border-warning shadow-lg rounded-geek">
                                                <div class="modal-header border-bottom border-secondary">
                                                    <h5 class="modal-title text-warning fw-bold text-uppercase" style="font-family: 'Orbitron', sans-serif;">
                                                        <i class="bi bi-radar"></i> Loot Radar Activated
                                                    </h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body p-4 text-center">
                                                    <h4 class="text-light fw-bold mb-3">@produto.Nome</h4>
                                                    <p class="text-muted font-monospace mb-4">Enter your email to get alerted when this item is back in stock.</p>
                                                    
                                                    <form asp-controller="Home" asp-action="AviseMe" method="post">
                                                        <input type="hidden" name="produtoId" value="@produto.Id" />
                                                        <div class="input-group mb-3">
                                                            <span class="input-group-text bg-black border-secondary text-warning"><i class="bi bi-envelope-at"></i></span>
                                                            <input type="email" name="emailCliente" class="form-control form-control-geek border-secondary" placeholder="your.email@cyber.com" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-warning text-dark fw-bold w-100 text-uppercase py-2" style="font-family: 'Orbitron', sans-serif; letter-spacing: 1px;">
                                                            Track Inventory
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 bg-black border border-secondary rounded-geek mt-4">
                <h4 class="text-muted mb-3"><i class="bi bi-x-octagon display-4 d-block mb-2"></i>No Loot Found</h4>
                <a href="/Admin/Produtos" class="btn btn-neon-cyan mt-3 fw-bold">Register Products</a>
            </div>
        }
    </div>
</div>