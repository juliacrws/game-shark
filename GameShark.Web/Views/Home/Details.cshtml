@model GameShark.Domain.Entities.Produto
@using GameShark.Domain.Enums
@{
    ViewData["Title"] = Model.Nome;
}

@functions {
    public string ObterCorClassificacao(ClassificacaoIndicativa classificacao)
    {
        return classificacao switch
        {
            ClassificacaoIndicativa.Livre => "#0c9447",
            ClassificacaoIndicativa.Dez => "#0f75bc",
            ClassificacaoIndicativa.Doze => "#fbd304",
            ClassificacaoIndicativa.Quatorze => "#f47321",
            ClassificacaoIndicativa.Dezesseis => "#ed1c24",
            ClassificacaoIndicativa.Dezoito => "#000000",
            _ => "#6c757d"
        };
    }

    public string ObterTextoClassificacao(ClassificacaoIndicativa classificacao)
    {
        return classificacao == ClassificacaoIndicativa.Livre ? "L" : ((int)classificacao).ToString();
    }
}

<div class="container mt-5 mb-5">
    <div class="card card-geek border-secondary shadow-lg overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5 position-relative d-flex align-items-center justify-content-center p-4 border-end-1 border-secondary" style="background: radial-gradient(circle at center, rgba(188, 19, 254, 0.03) 0%, rgba(0,0,0,1) 100%);">
                
                <div class="position-absolute d-flex align-items-center justify-content-center fw-bold shadow" 
                     style="top: 20px; right: 20px; width: 45px; height: 45px; border-radius: 4px; 
                            background-color: @ObterCorClassificacao(Model.Classificacao); 
                            color: @(Model.Classificacao == ClassificacaoIndicativa.Doze ? "#000" : "#fff");
                            border: @(Model.Classificacao == ClassificacaoIndicativa.Dezoito ? "2px solid #fff" : "none");
                            font-size: 1.5rem; z-index: 2; font-family: 'Orbitron', sans-serif;" title="Classificação Indicativa (Ministério da Justiça)">
                    @ObterTextoClassificacao(Model.Classificacao)
                </div>

                @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                {
                    <img src="@Model.ImagemUrl" class="img-fluid rounded shadow-lg" alt="@Model.Nome" style="max-height: 500px; object-fit: contain; border: 1px solid rgba(255,255,255,0.1);">
                }
                else
                {
                    <i class="bi bi-image display-1 text-secondary"></i>
                }
            </div>
            
            <div class="col-md-7">
                <div class="card-body p-5">
                    <div class="d-flex gap-2 mb-3">
                        <span class="badge bg-neon-cyan text-dark fs-6 text-uppercase" style="font-family: 'Orbitron', sans-serif;">@Model.Plataforma?.Nome</span>
                        <span class="badge bg-secondary fs-6 text-uppercase" style="font-family: 'Orbitron', sans-serif;">@Model.Categoria?.Nome</span>
                    </div>

                    <h1 class="display-5 fw-bold text-light text-uppercase mb-4" style="font-family: 'Orbitron', sans-serif;">@Model.Nome</h1>
                    
                    <h2 class="text-neon-green fw-bold mb-4" style="font-family: 'Orbitron', sans-serif;">R$ @Model.Preco.ToString("N2")</h2>
                    
                    <h5 class="text-warning mb-3 text-uppercase" style="font-family: 'Orbitron', sans-serif;"><i class="bi bi-book"></i> Sobre o Jogo / Lore</h5>
                    <p class="text-light fs-5" style="line-height: 1.8; white-space: pre-wrap; font-family: 'Rajdhani', sans-serif; opacity: 0.9;">@Model.Descricao</p>
                    
                    <hr class="border-secondary my-4 opacity-50">

                    <div class="d-flex align-items-center justify-content-between mt-4 bg-darker-bg p-4 rounded-geek border border-secondary">
                        <div>
                            <span class="text-muted d-block text-uppercase small" style="font-family: 'Orbitron', sans-serif;">Status de Disponibilidade:</span>
                            @if (Model.Estoque > 0)
                            {
                                <span class="text-success fw-bold fs-5" style="font-family: 'Rajdhani', sans-serif;"><i class="bi bi-check-circle"></i> Em Arsenal (@Model.Estoque unidades)</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold fs-5" style="font-family: 'Rajdhani', sans-serif;"><i class="bi bi-x-circle"></i> Esgotado</span>
                            }
                        </div>

                        @if (Model.Estoque > 0)
                        {
                            <form asp-controller="Carrinho" asp-action="Adicionar" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-neon-cyan btn-lg fw-bold px-5 py-3">
                                    <i class="bi bi-cart-plus"></i> Securing Loot
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos específicos */
    .bg-neon-cyan { background-color: var(--neon-cyan); }
    .text-neon-green { color: var(--neon-green); }
    .border-end-1 { border-right: 1px solid !important; }
    .bg-darker-bg { background-color: var(--darker-bg); }
    .rounded-geek { border-radius: 8px; }
</style>