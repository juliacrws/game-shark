@model GameShark.Web.Models.RegisterVm
@{
    ViewData["Title"] = "Junte-se ao Clã";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card bg-black border-warning shadow-lg">
            <div class="card-header border-warning text-center">
                <h4 class="text-warning fw-bold mt-2"><i class="bi bi-controller"></i> Novo Player</h4>
                <p class="text-muted small mb-0">Crie seu save state no oceano digital</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Nome" class="form-label text-muted fw-bold">Nome de Jogador</label>
                        <input asp-for="Nome" class="form-control bg-dark text-light border-secondary" placeholder="Ex: Mestre Kame" />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-muted fw-bold">E-mail</label>
                        <input asp-for="Email" type="email" class="form-control bg-dark text-light border-secondary" placeholder="player@gameshark.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Senha" class="form-label text-muted fw-bold">Senha de Acesso</label>
                        <div class="input-group">
                            <input asp-for="Senha" type="password" class="form-control bg-dark text-light border-secondary" placeholder="Escolha uma senha forte" id="campoSenha" />
                            <button class="btn btn-outline-secondary border-secondary" type="button" onclick="toggleSenha()">
                                <i class="bi bi-eye" id="iconeSenha"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Senha" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold text-dark py-2 fs-5">Criar Conta e Iniciar Quest</button>
                    
                    <div class="text-center mt-4 pt-3 border-top border-secondary">
                        <span class="text-muted small">Já tem um save state?</span><br />
                        <a asp-action="Login" class="text-info text-decoration-none fw-bold">Faça Login aqui</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleSenha() {
            var input = document.getElementById("campoSenha");
            var icone = document.getElementById("iconeSenha");
            
            if (input.type === "password") {
                input.type = "text";
                icone.classList.remove("bi-eye");
                icone.classList.add("bi-eye-slash"); // Muda pro olhinho cortado
            } else {
                input.type = "password";
                icone.classList.remove("bi-eye-slash");
                icone.classList.add("bi-eye"); // Volta pro olhinho normal
            }
        }
    </script>
}