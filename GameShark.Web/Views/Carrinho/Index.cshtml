@model IEnumerable<GameShark.Web.Models.CarrinhoItemVm>
@{
    ViewData["Title"] = "Inventário de Loot";
    decimal valorTotal = Model != null && Model.Any() ? Model.Sum(i => i.SubTotal) : 0;
}

<div class="container mt-4 mb-5">
    
    <div class="card-geek p-4 mb-4 shadow-lg d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h2 class="text-neon-cyan fw-bold text-uppercase mb-0" style="font-family: 'Orbitron', sans-serif; letter-spacing: 1px;">
                <i class="bi bi-cart4 me-2"></i> Inventário de Loot
            </h2>
            <small class="text-light font-monospace opacity-75">STATUS: @(Model != null && Model.Any() ? "CARREGADO" : "VAZIO")</small>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-neon-cyan text-uppercase fw-bold px-4 py-2 shadow-sm" style="font-family: 'Orbitron', sans-serif; letter-spacing: 1px;">
            <i class="bi bi-arrow-left me-2"></i> Continuar Explorando
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card card-geek shadow-lg">
                    <div class="card-body p-0 overflow-hidden rounded">
                        <table class="table table-dark table-hover table-borderless align-middle mb-0" style="background: transparent;">
                            <thead class="border-bottom border-neon-cyan text-uppercase text-light" style="font-family: 'Orbitron', sans-serif; font-size: 0.85rem; background: rgba(0,0,0,0.5);">
                                <tr>
                                    <th class="ps-4 py-3">Item</th>
                                    <th class="text-center py-3">Qtd</th>
                                    <th class="text-end py-3">Preço</th>
                                    <th class="text-center pe-4 py-3">Descartar</th>
                                </tr>
                            </thead>
                            <tbody style="font-family: 'Rajdhani', sans-serif; background: transparent;">
                                @foreach (var item in Model)
                                {
                                    <tr class="border-bottom border-secondary transition-hover" style="background: transparent;">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center gap-3">
                                                @if (!string.IsNullOrEmpty(item.ImagemUrl))
                                                {
                                                    <img src="@item.ImagemUrl" class="rounded border border-secondary shadow-sm cyber-img p-0" style="width: 70px; height: 70px; object-fit: cover;" alt="@item.Nome" />
                                                }
                                                else
                                                {
                                                    <div class="bg-black rounded border border-secondary d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                                                        <i class="bi bi-controller text-muted fs-3"></i>
                                                    </div>
                                                }
                                                <div>
                                                    <h5 class="fw-bold text-light mb-1">@item.Nome</h5>
                                                    <span class="badge border border-neon-cyan text-neon-cyan fw-bold text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">@item.Plataforma</span>
                                                </div>
                                            </div>
                                        </td>
                                        
                                        <td class="text-center py-3">
                                            <form asp-action="AtualizarQuantidade" method="post" class="d-inline-flex align-items-center bg-black border border-secondary rounded-pill p-1 shadow-sm">
                                                <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                                
                                                <button type="submit" name="acao" value="diminuir" class="btn btn-sm btn-dark rounded-circle text-neon-cyan border-0 fw-bold d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                                    <i class="bi bi-dash"></i>
                                                </button>
                                                
                                                <span class="mx-2 fw-bold text-light" style="width: 30px; font-size: 1.1rem;">@item.Quantidade</span>
                                                
                                                <button type="submit" name="acao" value="aumentar" class="btn btn-sm btn-dark rounded-circle text-neon-cyan border-0 fw-bold d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </form>
                                        </td>

                                        <td class="text-end py-3 pe-3 fs-5 fw-bold text-neon-green">
                                            R$ @item.SubTotal.ToString("N2")
                                        </td>
                                        
                                        <td class="text-center py-3 pe-4">
                                            <form asp-action="Remover" asp-route-id="@item.ProdutoId" method="post">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle d-flex align-items-center justify-content-center mx-auto cyber-buy-btn" style="width: 35px; height: 35px;" title="Descartar Item">
                                                    <i class="bi bi-trash3-fill"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card card-geek shadow-lg rounded-geek sticky-top" style="top: 100px;">
                    <div class="card-body p-4">
                        <h4 class="text-uppercase fw-bold text-light mb-4 border-bottom border-secondary pb-2" style="font-family: 'Orbitron', sans-serif;">
                            <i class="bi bi-receipt-cutoff text-neon-green me-2"></i> Resumo da Missão
                        </h4>
                        
                        <div class="d-flex justify-content-between mb-3 text-light opacity-75 fw-bold font-monospace">
                            <span>Subtotal:</span>
                            <span>R$ @valorTotal.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 text-light opacity-75 fw-bold font-monospace">
                            <span>Taxas:</span>
                            <span class="text-neon-cyan">Isento</span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-end mb-4 pt-3 border-top border-secondary">
                            <span class="text-uppercase fw-bold text-light" style="font-family: 'Orbitron', sans-serif; font-size: 0.9rem;">Total a Pagar</span>
                            <span class="display-6 text-neon-green fw-bold mb-0" style="font-family: 'Orbitron', sans-serif; text-shadow: 0 0 10px rgba(57, 255, 20, 0.3);">R$ @valorTotal.ToString("N2")</span>
                        </div>
                        
                        <form asp-action="FinalizarCompra" method="post" class="d-grid mt-4">
                            <button type="submit" class="btn btn-neon-green btn-lg fw-bold text-uppercase py-3 d-flex justify-content-center align-items-center gap-2 btn-glow" style="font-family: 'Orbitron', sans-serif; letter-spacing: 1px;">
                                <i class="bi bi-credit-card-fill"></i> Finalizar Compra
                            </button>
                        </form>
                        
                        <div class="text-center mt-3">
                            <small class="text-light opacity-50"><i class="bi bi-shield-lock-fill text-neon-cyan"></i> Transação 100% Segura</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row justify-content-center mt-5">
            <div class="col-md-6 text-center">
                <div class="card card-geek rounded-geek p-5 shadow-lg">
                    <i class="bi bi-cart-x display-1 text-neon-cyan mb-4 holographic-flicker opacity-50"></i>
                    <h3 class="text-light fw-bold text-uppercase" style="font-family: 'Orbitron', sans-serif;">Inventário Vazio</h3>
                    <p class="text-light opacity-75 mb-4 font-monospace">O teu cart de loot não possui itens no momento. Explore o catálogo para encontrar novos equipamentos.</p>
                    <a href="/" class="btn btn-neon-cyan btn-lg fw-bold text-uppercase px-5 py-3" style="font-family: 'Orbitron', sans-serif; letter-spacing: 1px;">
                        <i class="bi bi-search me-2"></i> Buscar Loot
                    </a>
                </div>
            </div>
        </div>
    }
</div>